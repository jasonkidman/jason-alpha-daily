<!doctype html>
<html lang="zh-CN"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ meta.title }}｜{{ meta.date }}</title>
<style>
:root{--navy:#0B1736;--blue:#1E4B8F;--cyan:#3F8CFF;--ink:#172033;--muted:#6B7485;--line:#E2E8F1;--soft:#F3F6FA;--green:#0E9F6E;--red:#D9485F;--amber:#D99213;--white:#fff}*{box-sizing:border-box}body{margin:0;background:#DDE3ED;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",Arial,sans-serif;color:var(--ink)}.page{width:1440px;height:1880px;margin:0 auto;background:#F7F9FC;padding:34px 44px 74px;overflow:hidden}.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}.brand{display:flex;gap:13px;align-items:center}.mark{width:42px;height:42px;border-radius:11px;background:linear-gradient(135deg,var(--navy),var(--cyan));display:grid;place-items:center;color:#fff;font-weight:800;font-size:17px}.brand h1{margin:0;font-size:28px;color:var(--navy)}.subtitle{font-size:12px;color:var(--muted);letter-spacing:.8px;margin-top:3px}.datebox{text-align:right}.date{font-weight:800;color:var(--navy);font-size:17px}.cutoff{font-size:11px;color:var(--muted);margin-top:4px}.hero{background:linear-gradient(135deg,#0B1736,#123B76);color:#fff;border-radius:16px;padding:18px 22px;display:grid;grid-template-columns:1.8fr .7fr;gap:18px;align-items:center;box-shadow:0 10px 28px rgba(11,23,54,.15)}.hero h2{font-size:23px;margin:0 0 7px}.hero p{margin:0;color:#D9E6FA;font-size:14px;line-height:1.6}.status{text-align:right}.pill{display:inline-block;padding:5px 10px;background:rgba(255,255,255,.13);border-radius:999px;font-size:10px;letter-spacing:.5px}.signal{font-size:32px;font-weight:800;margin-top:8px}.signal small{font-size:12px;color:#BFD0EF}.cards{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin:12px 0}.card,.panel{background:#fff;border:1px solid var(--line);box-shadow:0 4px 12px rgba(28,44,76,.04)}.card{border-radius:13px;padding:13px 15px}.label{font-size:11px;color:var(--muted);margin-bottom:6px}.value{font-size:25px;font-weight:800;color:var(--navy);line-height:1.05}.unit{font-size:12px;color:#7A8495}.delta{font-size:11px;font-weight:700;margin-top:6px}.green{color:var(--green)}.red{color:var(--red)}.amber{color:var(--amber)}.progress{height:5px;background:#E7ECF4;border-radius:6px;margin-top:8px;overflow:hidden}.progress span{display:block;height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan))}.layout{display:grid;grid-template-columns:1.18fr .82fr;gap:12px;margin-top:12px}.panel{border-radius:14px;padding:15px 17px}.panel h3{font-size:16px;color:var(--navy);margin:0 0 9px}.hint{font-size:10px;color:var(--muted);margin:-4px 0 9px}.marketgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}.metric{background:var(--soft);border-radius:10px;padding:9px 10px}.metric .n{font-size:11px;color:var(--muted)}.metric .v{font-size:17px;font-weight:800;color:var(--navy);margin-top:3px}.metric .c{font-size:11px;font-weight:700;margin-top:2px}.bars{display:flex;flex-direction:column;gap:8px}.barrow{display:grid;grid-template-columns:70px 1fr 44px;align-items:center;gap:8px;font-size:11px}.bar{height:8px;background:#EDF1F7;border-radius:999px;overflow:hidden}.bar span{display:block;height:100%;border-radius:999px}.up{background:linear-gradient(90deg,#63CBAA,var(--green))}.down{background:linear-gradient(90deg,#F39AA9,var(--red))}.health{display:grid;grid-template-columns:130px 1fr;gap:14px;align-items:center}.gauge{width:118px;height:118px;border-radius:50%;background:conic-gradient(var(--green) 0 74%,#E8EDF5 74%);display:grid;place-items:center;position:relative}.gauge:before{content:"";width:84px;height:84px;border-radius:50%;background:#fff;position:absolute}.gauge .num{position:relative;font-size:27px;font-weight:800;color:var(--navy);text-align:center}.gauge small{display:block;font-size:9px;color:var(--muted)}.checks{display:grid;grid-template-columns:1fr 1fr;gap:6px}.check{background:var(--soft);border-radius:8px;padding:8px 9px;display:flex;justify-content:space-between;font-size:10px}.check b{color:var(--navy)}table{width:100%;border-collapse:collapse}th{font-size:10px;color:var(--muted);text-align:left;padding:0 0 7px;border-bottom:1px solid var(--line)}td{font-size:11px;padding:7px 0;border-bottom:1px solid #EEF2F7}tr:last-child td{border-bottom:none}td:nth-child(2),td:nth-child(3){text-align:right}.ticker{font-weight:800;color:var(--navy)}.split3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:12px}.list{display:flex;flex-direction:column;gap:7px}.item{display:flex;justify-content:space-between;gap:10px;padding-bottom:6px;border-bottom:1px solid #EEF2F7;font-size:11px}.item:last-child{border-bottom:none}.item b{color:var(--navy)}.item span{color:var(--muted);text-align:right}.action{background:linear-gradient(135deg,#F3F7FD,#EEF4FB);border:1px solid #CFDAEA;box-shadow:0 6px 16px rgba(28,44,76,.08);position:relative;overflow:hidden}.action:after{content:"";position:absolute;right:-100px;top:-120px;width:250px;height:250px;border-radius:50%;background:rgba(63,140,255,.07)}.action h3{color:var(--navy);font-size:18px;margin-bottom:11px;position:relative;z-index:1}.action h3:after{content:"TODAY'S DECISION";font-size:9px;letter-spacing:1.2px;color:#6681AA;margin-left:10px;font-weight:600}.actiongrid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;position:relative;z-index:1}.act{background:#fff;border:1px solid #DCE4F0;border-radius:10px;padding:11px 12px;box-shadow:0 2px 7px rgba(28,44,76,.07);min-height:61px}.act strong{font-size:14px;display:block;margin-bottom:4px}.act span{font-size:10px;color:#596579;line-height:1.45}.act:nth-child(1){border-left:4px solid var(--green)}.act:nth-child(2){border-left:4px solid var(--green)}.act:nth-child(3){border-left:4px solid var(--red)}.act:nth-child(4){border-left:4px solid var(--amber)}.footer{display:flex;justify-content:space-between;margin-top:18px;padding-top:11px;border-top:1px solid var(--line);font-size:9px;color:var(--muted)}

.change-up{color:var(--green)}.change-down{color:var(--red)}.change-flat{color:var(--amber)}
.sector-up{background:linear-gradient(90deg,#63CBAA,var(--green))}.sector-down{background:linear-gradient(90deg,#F39AA9,var(--red))}
</style></head><body><div class="page">
<div class="topbar"><div class="brand"><div class="mark">JA</div><div><h1>{{ meta.brand }}</h1><div class="subtitle">{{ meta.subtitle }}</div></div></div><div class="datebox"><div class="date">{{ meta.date }}</div><div class="cutoff">{{ meta.cutoff }}</div></div></div>
<section class="hero"><div><h2>{{ executive.headline }}</h2><p>{{ executive.summary }}</p></div><div class="status"><span class="pill">MARKET STATUS</span><div class="signal">{{ executive.status_cn }} <small>{{ executive.status_en }}</small></div></div></section>
<section class="cards">
<div class="card"><div class="label">牛市健康度</div><div class="value">{{ scores.market_health }}<span class="unit"> /10</span></div><div class="delta {{ scores.market_health_class }}">{{ scores.market_health_note }}</div></div>
<div class="card"><div class="label">机会指数</div><div class="value">{{ scores.opportunity }}<span class="unit"> /100</span></div><div class="delta {{ scores.opportunity_class }}">{{ scores.opportunity_note }}</div></div>
<div class="card"><div class="label">股票当前市值</div><div class="value">¥{{ portfolio.market_value_fmt }}</div><div class="delta {{ portfolio.return_class }}">{{ portfolio.return_pct_fmt }}</div></div>
<div class="card"><div class="label">浮动盈利</div><div class="value">¥{{ portfolio.profit_fmt }}</div><div class="delta {{ portfolio.return_class }}">累计投入 ¥{{ portfolio.invested_fmt }}</div></div>
<div class="card"><div class="label">{{ portfolio.milestone_label }}</div><div class="value">{{ portfolio.milestone_progress_fmt }}</div><div class="progress"><span style="width:{{ portfolio.milestone_progress }}%"></span></div><div class="delta">差 ¥{{ portfolio.milestone_gap_fmt }}</div></div>
</section>
<div class="layout"><section class="panel"><h3>全球市场概览</h3><div class="marketgrid">{% for item in global_markets %}<div class="metric"><div class="n">{{ item.name }}</div><div class="v">{{ item.value }}</div><div class="c {{ item.change_class }}">{{ item.change }}</div></div>{% endfor %}</div></section>
<section class="panel"><h3>Market Breadth & Sector Leadership</h3><div class="hint">{{ breadth.summary }}</div><div class="bars">{% for sector in breadth.sectors %}<div class="barrow"><span>{{ sector.name }}</span><div class="bar"><span class="{{ sector.bar_class }}" style="width:{{ sector.bar_width }}%"></span></div><b class="{{ sector.change_class }}">{{ sector.change }}</b></div>{% endfor %}</div></section></div>
<div class="layout"><section class="panel"><h3>Market Health Dashboard</h3><div class="health"><div class="gauge" style="background:conic-gradient(var(--green) 0 {{ scores.market_health_pct }}%,#E8EDF5 {{ scores.market_health_pct }}%)"><div class="num">{{ scores.market_health }}<small>综合健康度</small></div></div><div class="checks">{% for item in health_checks %}<div class="check"><b>{{ item.name }}</b><span class="{{ item.status_class }}">{{ item.status }}</span></div>{% endfor %}</div></div></section>
<section class="panel"><h3>回调机会提醒</h3><div class="hint">{{ drawdown.summary }}</div><table><tbody>{% for row in drawdown.levels %}<tr><td>{{ row.range }}</td><td class="{{ row.status_class }}">{{ row.status }}</td><td>{{ row.action }}</td></tr>{% endfor %}</tbody></table></section></div>
<div class="split3">
<section class="panel"><h3>美国宏观政策</h3><div class="list">{% for item in macro %}<div class="item"><b>{{ item.name }}</b><span>{{ item.value }}</span></div>{% endfor %}</div></section>
<section class="panel"><h3>AI / 科技 / SpaceX</h3><div class="list">{% for item in technology %}<div class="item"><b>{{ item.name }}</b><span>{{ item.value }}</span></div>{% endfor %}</div></section>
<section class="panel"><h3>未来5-20个交易日</h3><div class="list">{% for item in outlook %}<div class="item"><b>{{ item.name }}</b><span class="{{ item.value_class|default('') }}">{{ item.value }}</span></div>{% endfor %}</div></section></div>
<div class="layout"><section class="panel"><h3>中国市场与政策</h3><table><tbody>{% for item in china_markets %}<tr><td class="ticker">{{ item.name }}</td><td>{{ item.value }}</td><td class="{{ item.change_class }}">{{ item.change }}</td></tr>{% endfor %}</tbody></table><div class="hint" style="margin-top:8px">{{ china_summary }}</div></section>
<section class="panel"><h3>长期投资仪表盘</h3><div class="marketgrid">{% for item in long_term_dashboard %}<div class="metric"><div class="n">{{ item.name }}</div><div class="v {{ item.value_class|default('') }}">{{ item.value }}</div></div>{% endfor %}</div></section></div>
<section class="panel action" style="margin-top:12px"><h3>Action Center · 今日行动</h3><div class="actiongrid">{% for item in actions %}<div class="act"><strong class="{{ item.title_class }}">{{ item.title }}</strong><span>{{ item.detail }}</span></div>{% endfor %}</div></section>
<div class="footer"><div>固定模板 V1.0 · 数据驱动渲染 · 仅替换数据</div><div>{{ meta.brand }} V5 Professional</div></div>
</div></body></html>